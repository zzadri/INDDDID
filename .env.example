NODE_ENV=development
PORT=3000
CORS_ORIGIN=http://localhost:4200

DB_HOST=localhost
DB_PORT=5432
DB_NAME=inddid
DB_USER=inddid
DB_PASSWORD=inddid_secret
DATABASE_URL=postgresql://inddid:inddid_secret@localhost:5432/inddid?schema=public

JWT_SECRET=change_this_to_a_long_random_secret_in_production
COOKIE_SECURE=false

# ── Encryption key for Proxmox credentials stored at rest ──────────────────
# AES-256-GCM symmetric key. Two accepted formats:
#   1. 64-char hex string (32 bytes, recommended). Generate via:
#        openssl rand -hex 32
#   2. Any other string: hashed with SHA-256 to 32 bytes (dev convenience).
# Rotating this key invalidates every stored Proxmox config. Back them up first.
AES_SECRET=change_this_to_a_hex_32_bytes_key_in_production

# Docker graph deployment (backend -> Docker Desktop)
DOCKER_DEPLOY_ENABLED=true
DEPLOYMENTS_DIR=

# ═══════════════════════════════════════════════════════════════════════════
#  Proxmox / Terraform — CONFIG PAR PROJET (depuis V1.1)
# ═══════════════════════════════════════════════════════════════════════════
# La config Proxmox (endpoint, credentials, node, template, storage, gateway)
# n'est PLUS globale : chaque projet a sa propre configuration, chiffrée en
# base et saisie via l'UI du modeler (modale de déploiement → Config Proxmox).
#
# Les variables PROXMOX_DEFAULT_* ci-dessous servent UNIQUEMENT de valeurs
# pré-remplies dans l'UI lors de la création d'une nouvelle config projet.
# Elles sont optionnelles — laisse-les vides pour forcer la saisie manuelle.
#
#  Setup Proxmox (une seule fois, côté serveur PVE) :
#
#  1. Créer un utilisateur dédié + rôle dédié (moindre privilège) :
#       pveum role add TerraformProv -privs \
#         "VM.Allocate VM.Clone VM.Config.Disk VM.Config.Memory \
#          VM.Config.Network VM.Config.Options VM.Config.Cloudinit \
#          VM.PowerMgmt VM.Audit Datastore.AllocateSpace Datastore.Audit \
#          Pool.Allocate Sys.Audit SDN.Use"
#       pveum user add terraform-prov@pve --password 'STRONG_PASS'
#       pveum aclmod / -user terraform-prov@pve -role TerraformProv
#
#  2. Créer un token API (évite /access/ticket, plus rapide, plus sûr) :
#       pveum user token add terraform-prov@pve terraform -privsep 0
#       # → renvoie un secret UUID. Format final du token à coller dans l'UI :
#       #   terraform-prov@pve!terraform=<uuid-secret>
#
#  3. Préparer un template VM cloud-init (ID 9000 par défaut) :
#       cd /var/lib/vz/template/iso
#       wget https://cloud-images.ubuntu.com/jammy/current/jammy-server-cloudimg-amd64.img
#       virt-customize -a jammy-server-cloudimg-amd64.img --install qemu-guest-agent
#       qm create 9000 --name ubuntu-2204-cloud --memory 2048 --cores 2 \
#         --net0 virtio,bridge=vmbr0
#       qm importdisk 9000 jammy-server-cloudimg-amd64.img local-lvm
#       qm set 9000 --scsihw virtio-scsi-pci --scsi0 local-lvm:vm-9000-disk-0
#       qm set 9000 --ide2 local-lvm:cloudinit --boot c --bootdisk scsi0
#       qm set 9000 --serial0 socket --vga serial0 --agent enabled=1
#       qm template 9000
#
#  4. Télécharger un template LXC Ubuntu 22.04 :
#       pveam update
#       pveam download local ubuntu-22.04-standard_22.04-1_amd64.tar.zst
#
#  5. Dans l'UI INDDID : ouvrir un projet → Deploy → onglet Proxmox →
#     bouton "Config Proxmox" → saisir endpoint + token + node + template + storage.
#
# Aucune variable PROXMOX_* n'est lue par le backend : toute la config
# (endpoint, credentials, node, template, storage, gateway, lxc_template)
# est stockée chiffrée en base, par projet, et saisie via l'UI.
